# Industrial Safety Monitoring API - Environment Configuration Template
# Copy this file to .env and update values as needed

# ==================== Database Configuration ====================
# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./safety_monitoring.db

# For PostgreSQL (if using PostgreSQL instead):
# DATABASE_URL=postgresql://username:password@localhost:5432/safety_monitoring_db

# ==================== Server Configuration ====================
HOST=127.0.0.1
PORT=8000

# ==================== Security Configuration ====================
# Secret key for JWT encoding (change this in production!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Algorithm
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Application Configuration ====================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=True

# ==================== CORS Configuration ====================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=*

# ==================== Logging Configuration ====================
LOG_LEVEL=INFO

# ==================== Optional: Camera/CV Configuration ====================
# Camera stream URL
CAMERA_URL=http://camera.local/stream

# Detection confidence threshold
DETECTION_CONFIDENCE=0.7

# ==================== Optional: Email Configuration ====================
# For incident notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL=safety-team@company.com

# ==================== Optional: Analytics Configuration ====================
# Enable analytics
ENABLE_ANALYTICS=False
ANALYTICS_API_KEY=your-analytics-key

# ==================== Optional: Notification Configuration ====================
# Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== PostgreSQL Specific (if using PostgreSQL) ====================
POSTGRES_USER=safety_user
POSTGRES_PASSWORD=safety_password
POSTGRES_DB=safety_monitoring_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
